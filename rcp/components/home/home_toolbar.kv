#: import ToolbarButton rcp.components.toolbars.toolbar_button
#: import TwoStateButton rcp.components.toolbars.two_state_button
#: import Factory kivy.factory.Factory
#: import Keypad rcp.components.popups.keypad
#: import ModePopup rcp.components.popups.mode_popup

<HomeToolbar>:
  orientation: "vertical"
  width: self.height / 6
  size_hint_x: None
  size_hint_y: 1

  TwoStateButton:
    width: root.width
    label_true: "MM"
    label_false: "IN"
    value: app.formats.current_format == "MM"
    on_release: app.formats.toggle()
    size_hint_y: 1

  ToolbarButton:
    width: root.width
    text: "P{:d}".format(app.currentOffset)
    on_release: Factory.Keypad(integer=True).show(app, 'currentOffset')
    size_hint_y: 1
    font_size: min(self.height/3, self.width/3)

  TwoStateButton:
    width: root.width
    label_true: "ABS"
    label_false: "INC"
    value: app.abs_mode
    blink: app.board.blink and app.abs_mode
    on_release: app.abs_mode = not app.abs_mode
    size_hint_y: 1

  ToolbarButton:
    width: root.width
    font_name: "fonts/Font Awesome 6 Free-Solid-900.otf"
    text: "\ue2ca"
    on_press: app.manager.goto("plot")
    font_size: min(self.height/3, self.width/3)

    # Hide wizard button if show_wizard is False
    size_hint_y: 1 if app.formats.show_wizard else None
    height: self.height if app.formats.show_wizard else 0
    opacity: 1 if app.formats.show_wizard else 0
    disabled: not app.formats.show_wizard

  ToolbarButton:
    width: root.width
    text: root.current_mode_desc
    on_release:
      Factory.ModePopup().show_with_callback(app.set_mode, app.current_mode)
    size_hint_y: 1
    font_size: min(self.height/3, self.width/3)

  ToolbarButton:
    width: root.width
    font_name: "fonts/Font Awesome 6 Free-Solid-900.otf"
    text: "\uf085"
    on_press: app.manager.goto("setup_screen")
    size_hint_y: 1
    font_size: min(self.height/3, self.width/3)

  #Widget:
  #  size_hint_y: 1