#: import AutoSizeButton rcp.components.widgets.auto_size_button
#: import LedButton rcp.components.toolbars.led_button

<ElsAdvancedBar>:
  orientation: "horizontal"
  size_hint_y: None
  height: 128
  Label:
    text: "ADV\nELS"
    text_size: self.size
    font_size: self.height/3
    width: self.height
    size_hint_x: None
    color: app.formats.display_color
    halign: 'center'
    valign: 'middle'
  BoxLayout:
    orientation: "vertical"
    size_hint_x: None
    width: self.height
    LedButton:
      label: "Disengaged" # TODO
      checkbox_value: False # TODO
    LedButton:
      label: "Disarmed" # TODO
      checkbox_value: False # TODO
  Button:
    text: "Engage"
    size_hint_x: None
    width: self.height
  Button:
    text: "Retract"
    size_hint_x: None
    width: self.height
  Widget:
      # spacer
  BoxLayout:
    orientation: "vertical"
    size_hint_x: None
    width: self.height * 1.5
    Label:
      text: "Stop " + app.els.get_z_axis().axis_name
      text_size: self.size
      size_hint_y: 0.3
      font_size: self.height / 1.5
      color: app.formats.display_color
      halign: 'center'
      valign: 'top'
    AutoSizeButton:
      size_hint_y: 0.7
      font_name: app.formats.font_name
      max_font_size: min(self.height / 1.5, self.width/5)
      font_style: "bold"
      background_color: [0.2, 0.2, 0.2, 1]
      color: app.formats.display_color
      text: str(root.stop_position) # TODO
      text_size: self.size
      halign: 'center'
      valign: 'middle'
      on_press: 
        app.beep()
        Factory.Keypad().show(root, 'stop_position') #TODO
  BoxLayout:
    orientation: "vertical"
    size_hint_x: None
    width: self.height * 1.5
    Label:
      text: "Retract " + app.els.get_z_axis().axis_name
      text_size: self.size
      size_hint_y: 0.3
      font_size: self.height / 1.5
      color: app.formats.display_color
      halign: 'center'
      valign: 'top'
    AutoSizeButton:
      size_hint_y: 0.7
      font_name: app.formats.font_name
      max_font_size: min(self.height / 1.5, self.width/5)
      font_style: "bold"
      background_color: [0.2, 0.2, 0.2, 1]
      color: app.formats.display_color
      text: str(root.stop_position) # TODO
      text_size: self.size
      halign: 'center'
      valign: 'middle'
      on_press: 
        app.beep()
        Factory.Keypad().show(root, 'stop_position') #TODO
  Button: # Wizard button
    font_name: "fonts/Font Awesome 6 Free-Solid-900.otf"
    width: self.height
    size_hint_x: None
    font_size: min(self.height / 3, self.width/3)
    background_color: [0.2, 0.2, 0.2, 1]
    color: app.formats.display_color
    text: "\ue2ca"
    text_size: self.size
    halign: 'center'
    valign: 'middle'
    on_press: app.beep()
    #TODO - launch wizard
  Button: # Config button
    font_name: "fonts/Font Awesome 6 Free-Solid-900.otf"
    width: self.height
    size_hint_x: None
    font_size: min(self.height / 3, self.width/3)
    background_color: [0.2, 0.2, 0.2, 1]
    color: app.formats.display_color
    text: "\uf085"
    text_size: self.size
    halign: 'center'
    valign: 'middle'
    on_press: app.beep()
    #TODO - launch configurator
