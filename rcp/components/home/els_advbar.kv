#: import HoldButton rcp.components.widgets.hold_button
#: import TextHeaderButton rcp.components.toolbars.text_header_button

<ElsAdvancedBar>:
  orientation: "horizontal"
  size_hint_y: None
  height: 128

  #Label:
  #  text: "ADV\nELS"
  #  text_size: self.size
  #  font_size: self.height/3
  #  width: self.height
  #  size_hint_x: None
  #  color: app.formats.display_color
  #  halign: 'center'
  #  valign: 'middle'
  BoxLayout:
    orientation: "vertical"
    size_hint_x: None
    LedButton:
      label: "Engaged" if root.els_stop_engaged else "Disengaged"
      checkbox_value: root.els_stop_engaged
    LedButton:
      label: "Disarmed"
      checkbox_value: False
  Button:
    text: "Disengage" if root.els_stop_engaged else "Engage"
    size_hint_x: None
    width: self.height * 0.6
    on_release:
      app.beep()
      root.toggle_engage()

  BoxLayout:
    orientation: 'vertical'

    # ── Wizard instruction bar (if enabled) ───────────────────────────────────
    Label: # Wizard instruction bar
      id: label_instruction
      text: root.label_text
      text_size: self.size
      size_hint_y: 0.2
      font_size: 16
      halign: 'center'
      valign: 'top'
      canvas.before:
        Color:
          rgba: [0.2, 0.2, 0.2, 1]
        Rectangle:
          pos: self.pos
          size: self.size

    # ── Controls (varied by mode) ─────────────────────────────────────────────
    BoxLayout:
      orientation: 'horizontal'
      size_hint_y: 0.8

      # ── Start / Stop (wizard only) ──────────────────────────────────────────
      Button:
        id: btn_start_stop
        width: 96 if root.enable_wizard else 0
        size_hint_x: None
        opacity: 1 if root.enable_wizard else 0
        disabled: not root.enable_wizard
        text: "Stop" if root.is_running else "Start"
        font_size: self.height / 4
        font_style: "bold"
        background_color: [1, 0.2, 0.2, 1] if root.is_running else [0.3, 0.3, 0.3, 1]
        on_release: root.toggle_is_running()

      Widget: # spacer

      TextHeaderButton:
        id: btn_stop_z
        text_header: "Stop Z"
        text_button: root.stop_z_text
        blink_enable: root.current_state == "set_stop_z"
        width: self.height
        on_release: root.on_value_button_released("stop_z")

      TextHeaderButton:
        id: btn_start_z
        text_header: "Start Z"
        text_button: root.start_z_text
        blink_enable: root.current_state == "set_start_z"
        width: self.height if (root.enable_retract or root.enable_wizard) else 0
        opacity: 1 if (root.enable_retract or root.enable_wizard) else 0
        disabled: not (root.enable_retract or root.enable_wizard)
        on_release: root.on_value_button_released("start_z")

      Widget: # spacer

      TextHeaderButton:
        id: btn_major_dia
        text_header: "Major \u00f8"
        text_button: root.major_diameter_text
        blink_enable: root.current_state == "set_major_diameter"
        width: self.height if root.enable_wizard else 0
        opacity: 1 if root.enable_wizard else 0
        disabled: not root.enable_wizard

      TextHeaderButton:
        id: btn_minor_dia
        text_header: "Minor \u00f8"
        text_button: root.minor_diameter_text
        blink_enable: root.current_state == "set_minor_diameter"
        width: self.height if root.enable_wizard else 0
        opacity: 1 if root.enable_wizard else 0
        disabled: not root.enable_wizard
        on_release: root.on_value_button_released("minor_dia")

      Widget: # spacer

      # ── Action button (Set / Go / Cut / Next / Config when idle — wizard only)
      Button:
        id: btn_action
        width: self.height if root.enable_wizard else 0
        size_hint_x: None
        opacity: 1 if root.enable_wizard else 0
        disabled: not root.enable_wizard
        font_name: "fonts/iosevka-regular.ttf" if root.is_running else "fonts/Font Awesome 6 Free-Solid-900.otf"
        text: root.next_button_text if root.is_running else "\uf013"
        font_size: self.height / 4
        halign: "center"
        on_release: root.on_action_button_clicked()

      # ── Retract hold button ────────────────────────────────────────────────
      HoldButton:
        id: btn_retract
        font_name: "fonts/iosevka-regular.ttf"
        size_hint_x: None if root.retract_button_shown else 0
        width: self.height if root.retract_button_shown else 0
        opacity: 1 if root.retract_button_shown else 0
        disabled: not root.retract_button_usable
        text: 'Retract'
        font_size: self.height / 4
        halign: "center"
        on_press: root.on_retract_button_pressed()
        on_release: root.on_retract_button_released()

  # ── Mode selector buttons (wizard / retract toggles) ───────────────────
  BoxLayout:
    orientation: "vertical"
    size_hint_x: None
    width: self.height * 0.7

    Button:
      id: btn_wizard_toggle
      font_name: "fonts/Font Awesome 6 Free-Solid-900.otf"
      font_size: min(self.height / 3, self.width / 3)
      background_color: [0.3, 0.5, 0.3, 1] if root.enable_wizard else [0.2, 0.2, 0.2, 1]
      color: app.formats.display_color
      text: "\ue2ca"
      text_size: self.size
      halign: 'center'
      valign: 'middle'
      disabled: root.is_running
      on_release:
        app.beep()
        root.enable_wizard = not root.enable_wizard
        if root.enable_wizard: root.enable_retract = True

    Button:
      id: btn_retract_toggle
      font_name: "fonts/Font Awesome 6 Free-Solid-900.otf"
      font_size: min(self.height / 3, self.width / 3)
      background_color: [0.3, 0.5, 0.3, 1] if root.enable_retract else [0.2, 0.2, 0.2, 1]
      color: app.formats.display_color
      text: "\uf085"
      text_size: self.size
      halign: 'center'
      valign: 'middle'
      disabled: root.is_running or root.enable_wizard
      on_release:
        app.beep()
        root.enable_retract = not root.enable_retract
